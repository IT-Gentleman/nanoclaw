# Required: Telegram JID of the chat to send job postings to (e.g. tg:-1234567890)
JOBS_CHAT_JID=tg:YOUR_CHAT_ID

# Optional: IPC group folder name (default: main)
# JOBS_IPC_GROUP=main

# Optional: NanoClaw data directory (default: /data)
# DATA_DIR=/data

# Optional: WordPress REST API base URL (default: https://inthiswork.com/wp-json/wp/v2/posts)
# JOBS_API_BASE=https://inthiswork.com/wp-json/wp/v2/posts

# Optional: Comma-separated category IDs to filter (default: 191700167,191700168)
# JOBS_CATEGORIES=191700167,191700168

# Optional: Comma-separated tag IDs to filter (default: 191700264,191700269,191700187,191700391)
# JOBS_TAGS=191700264,191700269,191700187,191700391

# Optional: Number of posts per API page (default: 20)
# JOBS_PER_PAGE=20
